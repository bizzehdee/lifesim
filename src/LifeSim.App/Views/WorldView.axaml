<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LifeSim.App.ViewModels"
             xmlns:views="using:LifeSim.App.Views"
             xmlns:pres="using:LifeSim.App.Presentation"
             xmlns:conv="using:LifeSim.App.Converters"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
             x:Class="LifeSim.App.Views.WorldView"
             x:DataType="vm:WorldViewModel">

    <UserControl.Resources>
        <conv:ColourToBrushConverter x:Key="ColourToBrush" />
    </UserControl.Resources>

    <Grid RowDefinitions="*">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="240" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="360" MinWidth="260" MaxWidth="720" />
        </Grid.ColumnDefinitions>

        <!-- The map (the Fluent exception: full-bleed custom rendering) + zoom overlay -->
        <Panel Grid.Row="0" Grid.Column="0">
            <views:SimulationCanvas x:Name="MapCanvas"
                                    Scene="{Binding Scene}"
                                    SelectedOrganismId="{Binding SelectedOrganismId, Mode=TwoWay}" />
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="10"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="−" Width="34" Click="OnZoomOutClick" ToolTip.Tip="Zoom out" />
                <Button Content="+" Width="34" Click="OnZoomInClick" ToolTip.Tip="Zoom in" />
                <Button Content="⤢" Width="34" Click="OnResetViewClick" ToolTip.Tip="Fit to view (or double-click the map)" />
            </StackPanel>
        </Panel>

        <!-- Drag to resize the sidebar -->
        <GridSplitter Grid.Row="0" Grid.Column="1" Width="6" ResizeDirection="Columns"
                      Background="{DynamicResource SystemChromeMediumColor}" ToolTip.Tip="Drag to resize the sidebar" />

        <!-- Chrome: Info / Ranking tabs -->
        <TabControl Grid.Row="0" Grid.Column="2" SelectedIndex="{Binding SidebarTabIndex}">

            <!-- Info: at-a-glance summary + selected-organism inspector (colours/legend live behind the 🎨 button) -->
            <TabItem Header="Info">
                <!-- Padding on the content (not the ScrollViewer) so the scrollbar stays at the true right
                     edge and the extra right inset clears it off the right-aligned trait values. -->
                <ScrollViewer Padding="0">
                    <StackPanel Spacing="16" Margin="12,12,22,12">
                        <!-- Active world events (ice age, blight, …) — shown here now that the top bar is gone. -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasActiveEvents}">
                            <TextBlock Text="Active events" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding ActiveEvents}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border Background="#5A3A00" CornerRadius="4" Padding="8,2" Margin="0,0,6,6">
                                            <TextBlock Text="{Binding}" Foreground="#F5C451" FontWeight="SemiBold" FontSize="12" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="At a glance" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding Glance}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="pres:StatRow">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" Opacity="0.75" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12" FontWeight="SemiBold" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                <Button Content="📊 Full statistics" Command="{Binding ToggleStatisticsCommand}" />
                                <Button Content="🎨 Colours" Command="{Binding ToggleLegendCommand}" />
                            </StackPanel>
                            <CheckBox IsChecked="{Binding NotificationsEnabled}" Content="🔔 Notifications" Margin="0,4,0,0" />
                        </StackPanel>

                        <Border IsVisible="{Binding HasSelection}" BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource SystemChromeMediumColor}" Padding="0,12,0,0">
                            <StackPanel Spacing="10">
                                <Button Content="🌳 View lineage graph" HorizontalAlignment="Stretch"
                                        Command="{Binding ViewLineageGraphCommand}" IsEnabled="{Binding CanViewLineageGraph}" />
                                <ContentControl Content="{Binding Inspector}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Ranking: whole-simulation leaderboard (alive or dead), most → least successful -->
            <TabItem Header="Ranking">
                <Grid RowDefinitions="Auto,*,*" Margin="8">
                    <StackPanel Grid.Row="0" Spacing="2" Margin="4,4,4,8">
                        <TextBlock Text="Descendant score" FontWeight="SemiBold" />
                        <TextBlock FontSize="11" Opacity="0.65" TextWrapping="Wrap"
                                   Text="children + ½ grandchildren + ¼ great-grandchildren · auto-updates" />
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Ranking}"
                             SelectedItem="{Binding SelectedRankingEntry, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="pres:RankingEntry">
                                <Grid ColumnDefinitions="30,*,Auto" ColumnSpacing="6">
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock FontSize="11" Opacity="0.7" Text="{Binding Score, StringFormat='score {0:F2}'}" />
                                            <TextBlock FontSize="11" Opacity="0.7" Text="{Binding Children, StringFormat='· children {0}'}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#3FB950" Text="alive" IsVisible="{Binding IsAlive}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11"
                                               Opacity="0.6" Text="dead" IsVisible="{Binding !IsAlive}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="2" RowDefinitions="Auto,*">
                        <Button Grid.Row="0" Content="🌳 View lineage graph" Margin="4,6" HorizontalAlignment="Left"
                                Command="{Binding ViewLineageGraphCommand}" IsEnabled="{Binding CanViewLineageGraph}" />
                        <ScrollViewer Grid.Row="1" Padding="0">
                            <ContentControl Content="{Binding RankingDetail}" Margin="4,4,22,4" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Organisms: every currently-alive organism, sortable; click to jump to its stats -->
            <TabItem Header="Organisms">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="4,4,4,8" VerticalAlignment="Center">
                        <TextBlock Text="Sort by" VerticalAlignment="Center" FontSize="12" />
                        <ComboBox ItemsSource="{Binding OrganismSortKeys}" SelectedItem="{Binding OrganismSortKey}" MinWidth="120" />
                        <CheckBox Content="Descending" IsChecked="{Binding OrganismSortDescending}" VerticalAlignment="Center" />
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding OrganismList}"
                             SelectedItem="{Binding SelectedOrganismRow, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="pres:OrganismRow">
                                <StackPanel Margin="0,1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock FontSize="11" Opacity="0.7" Text="{Binding Age, StringFormat='age {0}'}" />
                                        <TextBlock FontSize="11" Opacity="0.7" Text="{Binding CellCount, StringFormat='· cells {0:F1}'}" />
                                        <TextBlock FontSize="11" Opacity="0.7" Text="{Binding Children, StringFormat='· children {0}'}" />
                                        <TextBlock FontSize="11" Opacity="0.7" Text="{Binding Score, StringFormat='· score {0:F2}'}" />
                                        <TextBlock FontSize="11" Opacity="0.7" Text="{Binding BrainNodes, StringFormat='· nodes {0}'}" />
                                        <TextBlock FontSize="11" Opacity="0.7" Text="{Binding PreyCount, StringFormat='· prey {0}'}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Lineage graph overlay (over the whole view) -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                IsVisible="{Binding IsLineageGraphVisible}" Background="#CC0E1013">
            <Border Margin="40" Padding="16" CornerRadius="8" Background="{DynamicResource SystemChromeMediumColor}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <TextBlock Text="{Binding LineageGraphTitle}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Parent gens" VerticalAlignment="Center" FontSize="12" />
                            <NumericUpDown Width="110" Value="{Binding MaxParentGens}"
                                           Minimum="0" Maximum="100" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />
                            <TextBlock Text="Child gens" VerticalAlignment="Center" FontSize="12" Margin="6,0,0,0" />
                            <NumericUpDown Width="110" Value="{Binding MaxChildGens}"
                                           Minimum="0" Maximum="100" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />
                            <Button Content="Close" Command="{Binding CloseLineageGraphCommand}" Margin="6,0,0,0" />
                        </StackPanel>
                    </Grid>
                    <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" FontSize="11" Opacity="0.65"
                               Text="founder at top · generations descend · green = alive, grey = dead, amber = selected" />
                    <Border Background="#12141A" CornerRadius="4">
                        <views:LineageGraphControl Graph="{Binding LineageGraph}" />
                    </Border>
                </DockPanel>
            </Border>
        </Border>

        <!-- Global statistics overlay -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                IsVisible="{Binding IsStatisticsVisible}" Background="#CC0E1013">
            <Border Margin="60,40" Padding="16" CornerRadius="8" MaxWidth="640"
                    Background="{DynamicResource SystemChromeMediumColor}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <TextBlock Text="Global statistics" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Close" Command="{Binding CloseStatisticsCommand}" />
                    </Grid>

                    <!-- Founding-type composition: share-over-time chart + live scoreboard (only when types were seeded) -->
                    <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,14" IsVisible="{Binding HasFoundingTypeBreakdown}">
                        <TextBlock Text="Population by type — share over time" FontWeight="SemiBold" FontSize="13" Opacity="0.85" />
                        <Border CornerRadius="4" ClipToBounds="True" Height="110" Background="{DynamicResource SystemChromeLowColor}">
                            <views:CompositionChartControl Chart="{Binding FoundingTypeChart}" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding FoundingTypeStandings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pres:FoundingTypeStanding">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1" ColumnSpacing="6">
                                        <Border Grid.Column="0" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center" Background="{Binding Swatch}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center">
                                            <Run Text="{Binding Count}" FontWeight="SemiBold" />
                                            <Run Text="{Binding SharePercent, StringFormat=' ({0:F0}%)'}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <ScrollViewer Padding="0">
                        <ItemsControl ItemsSource="{Binding Statistics}" Margin="0,0,16,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pres:StatSection">
                                    <StackPanel Margin="0,0,0,14" Spacing="3">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Opacity="0.85" />
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="pres:StatRow">
                                                    <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" Opacity="0.75" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12" FontWeight="SemiBold" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <!-- Colours overlay: colour mode + legend, behind the 🎨 button -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                IsVisible="{Binding IsLegendVisible}" Background="#CC0E1013">
            <Border Margin="60,40" Padding="16" CornerRadius="8" MaxWidth="420"
                    Background="{DynamicResource SystemChromeMediumColor}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <TextBlock Text="Colours" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Close" Command="{Binding CloseLegendCommand}" />
                    </Grid>
                    <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,12">
                        <TextBlock Text="Colour mode" FontWeight="SemiBold" FontSize="12" Opacity="0.8" />
                        <ComboBox ItemsSource="{Binding ColourModes}" SelectedItem="{Binding ColourMode}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <ScrollViewer Padding="0">
                        <ItemsControl ItemsSource="{Binding Legend}" Margin="0,0,16,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="pres:LegendSection">
                                    <StackPanel Margin="0,0,0,8" Spacing="4">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Opacity="0.8" />
                                        <ItemsControl ItemsSource="{Binding Entries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="pres:LegendEntry">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1">
                                                        <Border Width="16" Height="16" CornerRadius="3"
                                                                Background="{Binding Colour, Converter={StaticResource ColourToBrush}}" />
                                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" FontSize="12" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
