<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:LifeSim.App.ViewModels"
                xmlns:views="using:LifeSim.App.Views"
                mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
                x:Class="LifeSim.App.Views.MainView"
                x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Control deck (chrome — follows the Fluent house rules) -->
        <Border DockPanel.Dock="Top" Padding="10,8" Background="{DynamicResource SystemChromeMediumColor}">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="▶ Play" Command="{Binding PlayCommand}" IsEnabled="{Binding HasWorld}" IsVisible="{Binding LiveCapable}" />
                <Button Content="⏸ Pause" Command="{Binding PauseCommand}" IsEnabled="{Binding HasWorld}" IsVisible="{Binding LiveCapable}" />
                <Button Content="⏭ Step" Command="{Binding StepCommand}" IsEnabled="{Binding HasWorld}" IsVisible="{Binding LiveCapable}" />
                <Button Content="⟳ New…" Command="{Binding ShowSetupCommand}" />

                <TextBlock Text="Speed" VerticalAlignment="Center" Margin="8,0,0,0" IsVisible="{Binding LiveCapable}" />
                <Slider Width="120" Minimum="1" Maximum="1000" Value="{Binding TicksPerSecond}" VerticalAlignment="Center" IsVisible="{Binding LiveCapable}"
                        ToolTip.Tip="Ticks per second (drag to the far right for unthrottled max speed)" />

                <Border Width="1" Background="{DynamicResource SystemChromeHighColor}" Margin="6,2" />

                <Button Content="Save…" Click="OnSaveClick" IsEnabled="{Binding HasWorld}" />
                <Button Content="Load…" Click="OnLoadClick" />

                <TextBox Width="200" PlaceholderText="sim serve URL" Text="{Binding StreamUrl}" VerticalAlignment="Center" />
                <Button Content="Connect stream" Command="{Binding ConnectCommand}" />

                <Border Width="1" Background="{DynamicResource SystemChromeHighColor}" Margin="6,2" />

                <TextBlock Text="Edit energy" VerticalAlignment="Center" />
                <Slider Width="100" Minimum="0" Maximum="100" Value="{Binding EditEnergy}" VerticalAlignment="Center" />
                <Button Content="Apply" Command="{Binding ApplyEditCommand}" IsEnabled="{Binding World.HasSelection}" />
            </StackPanel>
        </Border>

        <Panel>
            <!-- The shared world view (once a world exists). The wrapper keeps the MainViewModel
                 context for IsVisible; the inner view switches DataContext to the WorldViewModel. -->
            <Panel IsVisible="{Binding HasWorld}">
                <views:WorldView DataContext="{Binding World}" />
            </Panel>

            <!-- New-world setup (before the simulation starts) -->
            <ScrollViewer IsVisible="{Binding !HasWorld}" HorizontalScrollBarVisibility="Disabled">
                <Border MaxWidth="680" Margin="24" Padding="24" CornerRadius="8"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Background="{DynamicResource SystemChromeLowColor}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="New World" FontSize="22" FontWeight="Bold" />
                        <TextBlock Opacity="0.75" TextWrapping="Wrap"
                                   Text="Set the starting parameters, then create the world. The engine stays paused until you press Play." />

                        <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Seed" VerticalAlignment="Center" />
                            <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <NumericUpDown Grid.Column="0" Value="{Binding Seed}"
                                               Minimum="0" Maximum="999999999" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />
                                <Button Grid.Column="1" Content="🎲" Command="{Binding RandomiseSeedCommand}" ToolTip.Tip="Randomise seed" />
                            </Grid>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Width (tiles)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Width}"
                                           Minimum="4" Maximum="1024" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Height (tiles)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Height}"
                                           Minimum="4" Maximum="1024" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Population" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding Population}"
                                           Minimum="1" Maximum="1000000" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Threads" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding ThreadCount}"
                                           Minimum="1" Maximum="{Binding MaxThreads}" Increment="1" FormatString="0" ParsingNumberStyle="Integer" />
                        </Grid>

                        <StackPanel Spacing="6">
                            <CheckBox IsChecked="{Binding CooperationEnabled}"
                                      Content="Cooperation (kin recognition &amp; energy sharing)" />
                            <TextBlock Opacity="0.6" FontSize="12" Margin="28,0,0,0" TextWrapping="Wrap"
                                       Text="Organisms can share energy and evolve how generous to be. Off = no sharing at all." />
                            <CheckBox IsChecked="{Binding SenescenceEnabled}"
                                      Content="Senescence (aging)" Margin="0,4,0,0" />
                            <TextBlock Opacity="0.6" FontSize="12" Margin="28,0,0,0" TextWrapping="Wrap"
                                       Text="Old organisms pay a growing metabolic cost so no lineage is immortal. Off = death only by starvation or predation." />
                            <CheckBox IsChecked="{Binding MulticellularEnabled}"
                                      Content="Multicellularity (differentiated bodies)" Margin="0,4,0,0" />
                            <TextBlock Opacity="0.6" FontSize="12" Margin="28,0,0,0" TextWrapping="Wrap"
                                       Text="Bodies can evolve many cells specialised to jobs (germ, feeder, store, defender, mover, sensor). Bigger bodies cost more but store more; the square-cube law caps size. Off = every organism is a single cell." />
                            <CheckBox IsChecked="{Binding EntropyBehaviour}"
                                      Content="Entropy (unrepeatable life)" Margin="0,4,0,0" />
                            <TextBlock Opacity="0.6" FontSize="12" Margin="28,0,0,0" TextWrapping="Wrap"
                                       Text="Seed gameplay randomness from entropy: the same seed gives the same map but different life every run. Off = fully reproducible from the seed. (A created run still saves/reloads exactly either way.)" />
                        </StackPanel>

                        <Expander Header="Founding population by type">
                            <StackPanel Spacing="8">
                                <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                                           Text="Seed the world with a mix of brain &quot;types&quot;. Give any a count above zero and they replace the Population field; leave all at zero to use it. Every type is only a starting point — all of them mutate and compete from tick 0. Copy a built-in and edit its rules, or add your own." />
                                <ItemsControl x:Name="TypeList" ItemsSource="{Binding FoundingTypes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BrainTypeRowViewModel">
                                            <Border Margin="0,0,0,6" Padding="10" CornerRadius="6" Background="{DynamicResource SystemChromeLowColor}">
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"
                                                                   IsVisible="{Binding !IsRemovable}" />
                                                        <TextBox Grid.Column="0" Text="{Binding Name}" PlaceholderText="Type name" HorizontalAlignment="Left" MinWidth="160"
                                                                 IsVisible="{Binding IsRemovable}" />
                                                        <NumericUpDown Grid.Column="1" Width="120" Minimum="0" Maximum="1000000" Increment="1" FormatString="0"
                                                                       Value="{Binding Count}" VerticalAlignment="Center" />
                                                        <Button Grid.Column="2" Content="✕" VerticalAlignment="Center" ToolTip.Tip="Remove this custom type"
                                                                IsVisible="{Binding IsRemovable}"
                                                                Command="{Binding #TypeList.((vm:MainViewModel)DataContext).RemoveTypeCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                    <CheckBox IsChecked="{Binding Sexual}" Content="Start sexual (mates &amp; recombines rather than cloning)"
                                                              ToolTip.Tip="Seed this type's founders with full sexuality; it still evolves from there." />
                                                    <Expander Header="Script" IsVisible="{Binding HasScript}">
                                                        <StackPanel Spacing="4">
                                                            <TextBox Text="{Binding ScriptText}" AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="120"
                                                                     FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
                                                            <TextBlock Text="{Binding ParseError}" TextWrapping="Wrap" FontSize="12" IsVisible="{Binding HasError}"
                                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                                                            <TextBlock Text="✓ compiles" FontSize="12" IsVisible="{Binding IsValid}"
                                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                                        </StackPanel>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="➕ Add custom type" Command="{Binding AddCustomTypeCommand}" HorizontalAlignment="Left" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Advanced: all simulation settings">
                            <StackPanel Spacing="6">
                                <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                                           Text="Every starting constant, grouped by category. Tweak any value; the Population and toggles above override their config entries." />
                                <ScrollViewer MaxHeight="420" Padding="0,0,10,0">
                                    <ItemsControl ItemsSource="{Binding AdvancedConfig.Groups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ConfigGroup">
                                                <StackPanel Margin="0,0,0,10" Spacing="2">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Margin="0,4,0,2" />
                                                    <ItemsControl ItemsSource="{Binding Fields}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:ConfigField">
                                                                <Grid ColumnDefinitions="*,150" Margin="0,1">
                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" VerticalAlignment="Center" />
                                                                    <NumericUpDown Grid.Column="1" Value="{Binding Number}" IsVisible="{Binding !IsBool}"
                                                                                   Increment="{Binding Increment}" FormatString="{Binding Format}" />
                                                                    <CheckBox Grid.Column="1" IsChecked="{Binding Flag}" IsVisible="{Binding IsBool}" HorizontalAlignment="Right" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <ItemsControl ItemsSource="{Binding Groups}" Margin="14,2,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:ConfigGroup">
                                                                <StackPanel Margin="0,2,0,4" Spacing="2">
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Opacity="0.85" />
                                                                    <ItemsControl ItemsSource="{Binding Fields}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="vm:ConfigField">
                                                                                <Grid ColumnDefinitions="*,150" Margin="0,1">
                                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" VerticalAlignment="Center" />
                                                                                    <NumericUpDown Grid.Column="1" Value="{Binding Number}" IsVisible="{Binding !IsBool}"
                                                                                                   Increment="{Binding Increment}" FormatString="{Binding Format}" />
                                                                                    <CheckBox Grid.Column="1" IsChecked="{Binding Flag}" IsVisible="{Binding IsBool}" HorizontalAlignment="Right" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Expander>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Create World" Command="{Binding CreateWorldCommand}" Classes="accent" />
                            <Button Content="💾 Save options…" Click="OnSaveOptionsClick" />
                            <Button Content="📂 Load options…" Click="OnLoadOptionsClick" />
                        </StackPanel>
                        <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Opacity="0.85" />
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>
