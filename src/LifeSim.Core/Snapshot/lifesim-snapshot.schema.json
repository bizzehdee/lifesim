{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifesim.local/snapshot.schema.json",
  "title": "LifeSim Snapshot",
  "description": "Envelope schema for a LifeSim world snapshot (lifesim.md §12). Nested configuration and the not-yet-modelled blocks are validated structurally; their internal shape is enforced by later phases.",
  "type": "object",
  "required": [
    "schema_version",
    "config_version",
    "simulation_version",
    "tick",
    "world",
    "configuration",
    "prng_streams",
    "evolution_bookkeeping",
    "ground_energy",
    "environment_modifiers",
    "organisms",
    "lineages",
    "edit_log"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+" },
    "config_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+" },
    "simulation_version": { "type": "string", "minLength": 1 },
    "tick": { "type": "integer", "minimum": 0 },
    "world": {
      "type": "object",
      "required": ["seed", "width", "height"],
      "properties": {
        "seed": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      }
    },
    "configuration": { "type": "object" },
    "prng_streams": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": { "type": "integer", "minimum": 0 },
        "minItems": 4,
        "maxItems": 4
      }
    },
    "evolution_bookkeeping": {
      "type": "object",
      "required": ["next_innovation_id", "next_organism_id"],
      "properties": {
        "next_innovation_id": { "type": "integer", "minimum": 0 },
        "next_organism_id": { "type": "integer", "minimum": 0 }
      }
    },
    "ground_energy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["x", "y", "energy"],
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "energy": { "type": "number", "minimum": 0 }
        }
      }
    },
    "debug_terrain": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["x", "y", "biome", "moisture", "temperature"],
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "biome": { "type": "string" },
          "moisture": { "type": "number" },
          "temperature": { "type": "number" }
        }
      }
    },
    "environment_modifiers": { "type": "array" },
    "organisms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["organism_id", "name", "x", "y", "energy", "age", "genome", "brain", "last_action_result"],
        "properties": {
          "organism_id": { "type": "integer", "minimum": 0 },
          "name": { "type": "string", "minLength": 1 },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "energy": { "type": "number", "minimum": 0, "maximum": 100 },
          "age": { "type": "integer", "minimum": 0 },
          "genome": {
            "type": "object",
            "required": ["size", "speed_capacity", "thermal_center", "thermal_width", "env_radius", "org_radius", "sensory_acuity"],
            "properties": {
              "size": { "type": "number" },
              "speed_capacity": { "type": "number" },
              "thermal_center": { "type": "number" },
              "thermal_width": { "type": "number" },
              "env_radius": { "type": "number" },
              "org_radius": { "type": "number" },
              "sensory_acuity": { "type": "number" }
            }
          },
          "brain": {
            "type": "object",
            "required": ["nodes", "connections", "network_type"],
            "properties": {
              "network_type": { "type": "string" },
              "nodes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "type", "activation", "state"],
                  "properties": {
                    "id": { "type": "integer", "minimum": 0 },
                    "type": { "type": "string" },
                    "activation": { "type": "string" },
                    "state": { "type": "number" }
                  }
                }
              },
              "connections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["innovation_id", "from", "to", "weight", "enabled"],
                  "properties": {
                    "innovation_id": { "type": "integer", "minimum": 0 },
                    "from": { "type": "integer", "minimum": 0 },
                    "to": { "type": "integer", "minimum": 0 },
                    "weight": { "type": "number" },
                    "enabled": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "last_action": { "type": ["string", "null"] },
          "last_action_result": { "type": "string" }
        }
      }
    },
    "lineages": { "type": "array" },
    "metrics": {
      "type": ["object", "null"],
      "properties": {
        "population": { "type": "integer", "minimum": 0 },
        "extinct": { "type": "boolean" }
      }
    },
    "edit_log": { "type": "array" }
  }
}
